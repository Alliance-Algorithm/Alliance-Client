<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Alliance.Client.Features.Video"
             x:Class="Alliance.Client.Features.Video.VideoView"
             x:DataType="vm:VideoViewModel"
             mc:Ignorable="d">
  <Border Background="{DynamicResource StageBackgroundBrush}"
          BorderBrush="{DynamicResource GridLineBrush}"
          BorderThickness="1">
    <Grid RowDefinitions="*,Auto">
      <Grid>
        <Grid RowDefinitions="Auto,*,Auto" Margin="32">
          <StackPanel Spacing="6">
            <TextBlock Classes="eyebrow" Text="Video Plane" />
            <TextBlock Classes="display-title" Text="{Binding StatusText}" />
          </StackPanel>

          <StackPanel Grid.Row="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="12">
            <Border Classes="status-chip outline-chip" HorizontalAlignment="Center">
              <TextBlock Classes="chip-text" Text="{Binding TransportHint}" />
            </Border>

            <TextBlock Classes="stage-message"
                       Text="{Binding PlaceholderMessage}"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
            <TextBlock Classes="mono-label" Text="{Binding FrameCounterLabel}" />
            <TextBlock Grid.Column="2" Classes="mono-label" Text="{Binding SourceHint}" />
          </Grid>
        </Grid>
      </Grid>

      <Border Grid.Row="1" Background="#0B121699" Padding="20,14">
        <TextBlock Classes="subtle" Text="{Binding Footnote}" TextWrapping="Wrap" />
      </Border>
    </Grid>
  </Border>
</UserControl>
