<!--
TeamPanel - 比赛信息面板控件

Outpost 与 Base 分两行显示，Outpost 在上，Base 在下。
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telemetry="using:Alliance.Client.Features.Telemetry"
             xmlns:local="using:Alliance.Client.Shared.Utils"
             x:Class="Alliance.Client.Features.Hud.TeamPanel"
             x:DataType="telemetry:TeamPanelSnapshot"
             mc:Ignorable="d">
    <Border Classes="hud-panel">
        <StackPanel Spacing="6">
            <!-- 建筑血量：Outpost 在上，Base 在下，显示当前/满血 -->
            <StackPanel Spacing="4">
                <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="8">
                    <TextBlock Classes="hud-bar-label"
                               Text="OUTPOST" />
                    <Border x:Name="OutpostBarBg"
                            Grid.Column="1"
                            Classes="hud-structure-bar-bg">
                        <Border Classes="hud-bar-fill-center"
                                Background="{Binding IsBlue, Converter={x:Static local:TeamHealthBrushConverter.Instance}}"
                                HorizontalAlignment="Left">
                            <Border.Width>
                                <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                    <Binding Path="OutpostHealthPercent" />
                                    <Binding Path="#OutpostBarBg.Bounds.Width" />
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Border>
                    <TextBlock Grid.Column="2"
                               Classes="hud-bar-label"
                               Text="{Binding OutpostHealthDisplay}" />
                </Grid>

                <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="8">
                    <TextBlock Classes="hud-bar-label"
                               Text="BASE" />
                    <Border x:Name="BaseBarBg"
                            Grid.Column="1"
                            Classes="hud-structure-bar-bg">
                        <Border Classes="hud-bar-fill-center"
                                Background="{Binding IsBlue, Converter={x:Static local:TeamHealthBrushConverter.Instance}}"
                                HorizontalAlignment="Left">
                            <Border.Width>
                                <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                    <Binding Path="BaseHealthPercent" />
                                    <Binding Path="#BaseBarBg.Bounds.Width" />
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Border>
                    <TextBlock Grid.Column="2"
                               Classes="hud-bar-label"
                               Text="{Binding BaseHealthDisplay}" />
                </Grid>
            </StackPanel>

            <!-- 第二行：累计总伤 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                <TextBlock Classes="hud-detail" Text="累计总伤" VerticalAlignment="Center" />
                <TextBlock Classes="hud-damage-value"
                           Text="{Binding DamageValueText}" />
            </StackPanel>

            <!-- 第三行：经济 -->
            <TextBlock Classes="hud-economy-value"
                       HorizontalAlignment="Center"
                       Text="{Binding EconomyDisplayText}" />
        </StackPanel>
    </Border>
</UserControl>
