<!--
HudOverlay - HUD主控件（整体布局容器）

整体布局向视觉稿靠拢：
中上：我方机器人 | 顶部状态条 + 16:9 视频图传 | 敌方机器人
底部：当前机器人 | RESERVED | MAP | EVENTS

IsHitTestVisible="False": 默认不拦截鼠标事件，允许穿透到视频层。
SETTINGS/IMAGE 按钮单独设 IsHitTestVisible="True" 以接收点击。
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Alliance.Client.Features.Hud"
             xmlns:video="using:Alliance.Client.Features.Video"
             xmlns:controls="using:Alliance.Client.Shared.Controls"
             x:Class="Alliance.Client.Features.Hud.HudOverlay"
             x:DataType="vm:HudOverlayViewModel"
             IsHitTestVisible="False"
             mc:Ignorable="d">
  <Grid x:Name="RootLayout"
        RowDefinitions="*,220"
        ColumnDefinitions="2*,6*,2*"
        RowSpacing="4" ColumnSpacing="4" Margin="16">

    <!-- ===== 中上：我方机器人 / 中央状态条 + 16:9 视频图传 / 敌方机器人 ===== -->
    <vm:RobotStatusBar Grid.Row="0" Grid.Column="0"
                       DataContext="{Binding AllyRobotsViewModel}" />

    <Grid Grid.Row="0" Grid.Column="1"
          RowDefinitions="56,*"
          RowSpacing="4">
      <Border Grid.Row="0" Classes="hud-topbar">
        <Grid>
          <Grid ColumnDefinitions="Auto,220,*" ColumnSpacing="14">
            <TextBlock Classes="hud-app-name"
                       Text="alliance-client"
                       VerticalAlignment="Center" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
              <TextBlock Classes="hud-status-text"
                         Text="{Binding Snapshot.MqttStatusText}"
                         MaxWidth="96" />
              <TextBlock Classes="hud-status-text"
                         Text="{Binding Snapshot.LastUpdateCompactText}"
                         MaxWidth="112" />
            </StackPanel>
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="8"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
            <Border Classes="hud-stage-chip">
              <TextBlock Text="{Binding Snapshot.StageText}" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentBrush}"
                         TextTrimming="CharacterEllipsis" />
            </Border>
            <TextBlock Classes="hud-countdown" Text="{Binding Snapshot.MatchTimeText}" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="8"
                      HorizontalAlignment="Right" VerticalAlignment="Top"
                      Margin="0,10,10,0"
                      IsHitTestVisible="True">
            <Border Classes="settings-btn"
                    PointerPressed="OnSettingsPressed">
              <TextBlock Text="SETTINGS"
                         FontSize="11" FontWeight="SemiBold"
                         FontFamily="{DynamicResource AppMono}"
                         Foreground="{DynamicResource TextBrush}"
                         VerticalAlignment="Center" />
            </Border>

            <Border Classes="settings-btn"
                    PointerPressed="OnImagePressed">
              <TextBlock Text="IMAGE"
                         FontSize="11" FontWeight="SemiBold"
                         FontFamily="{DynamicResource AppMono}"
                         Foreground="{DynamicResource TextBrush}"
                         VerticalAlignment="Center" />
            </Border>
          </StackPanel>
        </Grid>
      </Border>

      <controls:AspectRatioDecorator Grid.Row="1"
                                     AspectRatio="1.7777777777777777"
                                     VerticalAlignment="Top"
                                     HorizontalAlignment="Stretch">
        <Border Classes="hud-video-frame">
          <Grid>
            <video:VideoFeedControl Store="{Binding Video}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch" />

            <TextBlock Classes="hud-video-watermark"
                       Text="VIDEO FEED"
                       IsVisible="{Binding Video.IsWaitingForFrame}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <Grid VerticalAlignment="Top" Margin="12"
                  ColumnDefinitions="*,*" ColumnSpacing="8">
              <vm:TeamPanel x:Name="AllyTeamPanel"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            DataContext="{Binding Snapshot.AllyTeam}" />
              <vm:TeamPanel x:Name="EnemyTeamPanel"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            DataContext="{Binding Snapshot.EnemyTeam}" />
            </Grid>

            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12" Spacing="2">
              <TextBlock Classes="hud-caption" Text="{Binding Video.Snapshot.StatusText}" HorizontalAlignment="Right" />
              <TextBlock Classes="hud-detail" Text="{Binding Video.Snapshot.MetricsText}" HorizontalAlignment="Right" />
            </StackPanel>
          </Grid>
        </Border>
      </controls:AspectRatioDecorator>
    </Grid>

    <vm:RobotStatusBar Grid.Row="0" Grid.Column="2"
                       DataContext="{Binding EnemyRobotsViewModel}" />

    <!-- ===== 底部：当前机器人 / 预留 / 地图 / 事件 ===== -->
    <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
          RowDefinitions="*" ColumnDefinitions="*,*,*,*"
          ColumnSpacing="4">

      <!-- 左下：当前机器人面板 (2x2) -->
      <vm:CurrentRobotPanel Grid.Column="0"
                            DataContext="{Binding Snapshot.CurrentRobot}" />

      <!-- 中左下：预留区域 (2x2) -->
      <Border Grid.Column="1"
              Classes="hud-panel" VerticalAlignment="Stretch">
        <StackPanel Spacing="2" VerticalAlignment="Center" HorizontalAlignment="Center">
          <TextBlock Classes="hud-caption" Text="RESERVED" HorizontalAlignment="Center" />
          <TextBlock Classes="hud-detail" Text="--" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- 中右下：地图面板 (2x2) -->
      <Border Grid.Column="2"
              Classes="hud-panel" VerticalAlignment="Stretch">
        <StackPanel Spacing="2" VerticalAlignment="Center" HorizontalAlignment="Center">
          <TextBlock Classes="hud-caption" Text="MAP" HorizontalAlignment="Center" />
          <TextBlock Classes="hud-detail" Text="--" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- 右下：赛场事件消息面板 (2x2) -->
      <Border Grid.Column="3"
              Classes="hud-panel" VerticalAlignment="Stretch">
        <StackPanel Spacing="2" VerticalAlignment="Center" HorizontalAlignment="Center">
          <TextBlock Classes="hud-caption" Text="EVENTS" HorizontalAlignment="Center" />
          <TextBlock Classes="hud-detail" Text="--" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>

    </Grid>

  </Grid>
</UserControl>
