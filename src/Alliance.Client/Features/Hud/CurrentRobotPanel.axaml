<!--
CurrentRobotPanel - 当前操控机器人状态面板

渲染结构（四行等高）：
┌─────────────────────────────────┐
│ Robot 1  ████████████░░░  HP:450 │  ← 血条 + 血量
│ Lv.3  升级还需: 120  允许发弹量:28 │  ← 等级 + 升级经验 + 弹药
│ 剩余能量: 80/100 J █████████░░░░ │  ← 能量数字 + 能量条
│ ATK+15%  DEF+10%                 │  ← Buff 文字
└─────────────────────────────────┘

数据绑定：CurrentRobotPanelSnapshot
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:Alliance.Client.Shared.Utils"
             x:Class="Alliance.Client.Features.Hud.CurrentRobotPanel"
             x:DataType="telemetry:CurrentRobotPanelSnapshot"
             mc:Ignorable="d"
             xmlns:telemetry="using:Alliance.Client.Features.Telemetry">
    <Border Classes="hud-panel-accent">
        <Grid RowDefinitions="*,*,*,*" RowSpacing="2">
            <!-- 第一行：机器人ID + 血条 + HP数字 -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                <TextBlock Classes="hud-value" FontSize="15"
                           VerticalAlignment="Center"
                           Text="{Binding RobotLabel}" />
                <Border x:Name="HealthBarBg" Classes="hud-bar-bg-lg" Grid.Column="1" VerticalAlignment="Center">
                    <Border Classes="hud-bar-fill-lg"
                            Background="{Binding BarColorClass, Converter={x:Static local:HealthBarBrushConverter.Instance}}"
                            HorizontalAlignment="Left">
                        <Border.Width>
                            <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                <Binding Path="HealthPercent" />
                                <Binding Path="#HealthBarBg.Bounds.Width" />
                            </MultiBinding>
                        </Border.Width>
                    </Border>
                </Border>
                <TextBlock Grid.Column="2" Classes="hud-value" FontSize="15"
                           VerticalAlignment="Center"
                           Text="{Binding HealthText}" />
            </Grid>

            <!-- 第二行：等级 + 升级还需 + 允许发弹量 -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <TextBlock Classes="hud-value" FontSize="14"
                           VerticalAlignment="Center"
                           Text="{Binding LevelText}" />
                <TextBlock Grid.Column="1" Classes="hud-value" FontSize="14"
                           VerticalAlignment="Center"
                           Text="{Binding UpgradeNeededText}" />
                <TextBlock Grid.Column="2" Classes="hud-value" FontSize="14"
                           VerticalAlignment="Center"
                           Text="{Binding AmmoText}" />
            </Grid>

            <!-- 第三行：剩余能量数字 + 能量条 -->
            <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <TextBlock Classes="hud-value" FontSize="14"
                           VerticalAlignment="Center"
                           Text="{Binding ChassisEnergyText}" />
                <Border x:Name="EnergyBarBg" Classes="hud-bar-bg" Grid.Column="1" VerticalAlignment="Center">
                    <Border Classes="hud-bar-fill"
                            Background="{DynamicResource AccentBrush}"
                            HorizontalAlignment="Left">
                        <Border.Width>
                            <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                <Binding Path="ChassisEnergyPercent" />
                                <Binding Path="#EnergyBarBg.Bounds.Width" />
                            </MultiBinding>
                        </Border.Width>
                    </Border>
                </Border>
            </Grid>

            <!-- 第四行：Buff栏 -->
            <TextBlock Grid.Row="3" Classes="hud-value" FontSize="14"
                       VerticalAlignment="Center"
                       Text="{Binding BuffText}" />
        </Grid>
    </Border>
</UserControl>
