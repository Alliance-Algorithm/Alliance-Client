<!-- RobotStatusBar - 双方机器人侧栏，大卡片样式 -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:hud="using:Alliance.Client.Features.Hud"
             xmlns:vm="using:Alliance.Client.Features.Hud"
             xmlns:telemetry="using:Alliance.Client.Features.Telemetry"
             xmlns:local="using:Alliance.Client.Shared.Utils"
             x:Class="Alliance.Client.Features.Hud.RobotStatusBar"
             x:DataType="vm:RobotStatusBarViewModel"
             mc:Ignorable="d">
    <Border Classes="hud-panel" VerticalAlignment="Stretch" Padding="0">
        <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Classes="hud-robot-side-header">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="2">
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Classes="hud-robot-side-title"
                               Text="{Binding Caption}" />
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Classes="hud-robot-side-stat"
                               Text="{Binding AliveSummaryText}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                               Classes="hud-robot-side-stat"
                               Text="{Binding TotalHealthText}" />
                </Grid>
            </Border>

            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding Robots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="6" Columns="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="telemetry:RobotStatusSnapshot">
                        <Border Classes="hud-robot-card" Margin="6,3"
                                VerticalAlignment="Stretch"
                                Opacity="{Binding CardOpacity}">
                            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="5">
                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <Border Classes="hud-robot-slot-badge"
                                            Background="{Binding IsBlue, Converter={x:Static local:TeamHealthBrushConverter.Instance}}">
                                        <TextBlock Text="{Binding SlotLabel}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{DynamicResource AppMono}"
                                                   FontWeight="Bold"
                                                   Foreground="#FFFFFF"
                                                   FontSize="{Binding TextScale, RelativeSource={RelativeSource AncestorType=hud:RobotStatusBar}, Converter={x:Static local:ScaledDoubleConverter.Instance}, ConverterParameter=15}" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Classes="hud-robot-type"
                                                   Text="{Binding RobotTypeText}"
                                                   FontSize="{Binding TextScale, RelativeSource={RelativeSource AncestorType=hud:RobotStatusBar}, Converter={x:Static local:ScaledDoubleConverter.Instance}, ConverterParameter=15}" />
                                        <TextBlock Classes="hud-robot-state"
                                                   Text="{Binding StateText}"
                                                   FontSize="{Binding TextScale, RelativeSource={RelativeSource AncestorType=hud:RobotStatusBar}, Converter={x:Static local:ScaledDoubleConverter.Instance}, ConverterParameter=10}" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Classes="hud-robot-health-value"
                                               Text="{Binding HealthDisplayText}"
                                               IsVisible="{Binding ShowHealthBar}"
                                               FontSize="{Binding TextScale, RelativeSource={RelativeSource AncestorType=hud:RobotStatusBar}, Converter={x:Static local:ScaledDoubleConverter.Instance}, ConverterParameter=24}" />
                                </Grid>

                                <Border x:Name="RobotHealthBarBg"
                                        Grid.Row="1"
                                        Classes="hud-robot-health-bg"
                                        IsVisible="{Binding ShowHealthBar}">
                                    <Border Classes="hud-robot-health-fill"
                                            Background="{Binding IsBlue, Converter={x:Static local:TeamHealthBrushConverter.Instance}}"
                                            HorizontalAlignment="Left">
                                        <Border.Width>
                                            <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                                <Binding Path="HealthPercent" />
                                                <Binding Path="#RobotHealthBarBg.Bounds.Width" />
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                </Border>

                                <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6"
                                      VerticalAlignment="Bottom">
                                    <TextBlock Grid.Column="0"
                                               Classes="hud-robot-meta"
                                               Text="{Binding AmmoDisplayText}"
                                               IsVisible="{Binding !IsRadar}"
                                               FontSize="{Binding TextScale, RelativeSource={RelativeSource AncestorType=hud:RobotStatusBar}, Converter={x:Static local:ScaledDoubleConverter.Instance}, ConverterParameter=11}" />

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                                IsVisible="{Binding !IsRadar}">
                                        <Border Classes="hud-buff-chip" IsVisible="{Binding HasFirstBuff}">
                                            <TextBlock Text="{Binding FirstBuffText}"
                                                       Classes="hud-buff-chip-text"
                                                       FontSize="{Binding TextScale, RelativeSource={RelativeSource AncestorType=hud:RobotStatusBar}, Converter={x:Static local:ScaledDoubleConverter.Instance}, ConverterParameter=10}" />
                                        </Border>
                                        <Border Classes="hud-buff-chip" IsVisible="{Binding HasSecondBuff}">
                                            <TextBlock Text="{Binding SecondBuffText}"
                                                       Classes="hud-buff-chip-text"
                                                       FontSize="{Binding TextScale, RelativeSource={RelativeSource AncestorType=hud:RobotStatusBar}, Converter={x:Static local:ScaledDoubleConverter.Instance}, ConverterParameter=10}" />
                                        </Border>
                                        <TextBlock Classes="hud-robot-meta"
                                                   Text="BUFF --"
                                                   IsVisible="{Binding !HasFirstBuff}"
                                                   FontSize="{Binding TextScale, RelativeSource={RelativeSource AncestorType=hud:RobotStatusBar}, Converter={x:Static local:ScaledDoubleConverter.Instance}, ConverterParameter=11}" />
                                    </StackPanel>

                                    <Border Grid.Column="2" Classes="hud-radar-chip"
                                            IsVisible="{Binding IsRadarLocked}">
                                        <TextBlock Text="雷达锁定"
                                                   Classes="hud-radar-chip-text" />
                                    </Border>

                                    <TextBlock Grid.Column="0" Grid.ColumnSpan="3"
                                               Classes="hud-robot-meta"
                                               Text="{Binding RadarDetailText}"
                                               IsVisible="{Binding IsRadar}"
                                               HorizontalAlignment="Left"
                                               FontSize="{Binding TextScale, RelativeSource={RelativeSource AncestorType=hud:RobotStatusBar}, Converter={x:Static local:ScaledDoubleConverter.Instance}, ConverterParameter=11}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>
