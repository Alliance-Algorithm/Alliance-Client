<Styles xmlns="https://github.com/avaloniaui">
  <Style Selector="Border.hud-panel">
    <Setter Property="Background" Value="#091115CC" />
    <Setter Property="BorderBrush" Value="#3A6D72" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="TextBlock.hud-caption">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="TextBlock.hud-value">
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.hud-detail">
    <Setter Property="FontFamily" Value="{DynamicResource AppMono}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
  </Style>

  <Style Selector="Border.crosshair-line">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Opacity" Value="0.8" />
  </Style>

  <Style Selector="Border.crosshair-ring">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="#55D7C7" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Opacity" Value="0.65" />
  </Style>
</Styles>
