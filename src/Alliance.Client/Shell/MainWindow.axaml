<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:video="using:Alliance.Client.Features.Video"
        xmlns:hud="using:Alliance.Client.Features.Hud"
        xmlns:vm="using:Alliance.Client.Shell"
        x:Class="Alliance.Client.Shell.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1360"
        Height="820"
        MinWidth="1024"
        MinHeight="640"
        Title="{Binding WindowTitle}"
        Background="#000000"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        mc:Ignorable="d">
  <Grid>
    <!-- 视频画面 + HUD 叠层 -->
    <Grid>
      <video:VideoView DataContext="{Binding Video}" />
      <hud:HudOverlay DataContext="{Binding Hud}" />

      <!-- 左上角：连接状态 -->
      <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="18" Spacing="8">
        <Border Classes="status-chip warning-chip">
          <TextBlock Classes="chip-text" Text="{Binding MqttStatusLabel}" />
        </Border>
        <Border Classes="status-chip outline-chip">
          <TextBlock Classes="chip-text" Text="{Binding VideoStatusLabel}" />
        </Border>
      </StackPanel>

      <!-- 透明遮罩层（点击外部关闭下拉） -->
      <Border IsVisible="{Binding IsRobotDropdownOpen}"
              Background="Transparent"
              ZIndex="199"
              PointerPressed="OnOverlayPressed" />

      <!-- 右上角：机器人选择 -->
      <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="18" Spacing="4"
                  ZIndex="200">
        <Border Classes="status-chip accent-chip"
                PointerPressed="OnRobotSelectorPressed"
                Cursor="Hand">
          <TextBlock Classes="chip-text" Text="{Binding CurrentRobotLabel}" />
        </Border>
        <Border IsVisible="{Binding IsRobotDropdownOpen}"
                Background="#15202B"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="4"
                MinWidth="120"
                MaxHeight="240">
          <ListBox ItemsSource="{Binding RobotIdOptions}"
                   SelectedItem="{Binding SelectedRobotId}"
                   Background="Transparent"
                   BorderThickness="0"
                   Foreground="{DynamicResource TextBrush}"
                   FontSize="12"
                   FontWeight="SemiBold">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Padding="10,6"
                           Text="{Binding StringFormat='Robot {0}'}"
                           Foreground="{DynamicResource TextBrush}" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </StackPanel>

      <!-- 右下角：状态信息 -->
      <Border Classes="status-chip outline-chip"
              HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="18">
        <TextBlock Classes="chip-text" Text="{Binding StatusFootnote}" />
      </Border>
    </Grid>
  </Grid>
</Window>
