<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:video="using:Alliance.Client.Features.Video"
        xmlns:hud="using:Alliance.Client.Features.Hud"
        xmlns:vm="using:Alliance.Client.Shell"
        x:Class="Alliance.Client.Shell.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1360"
        Height="820"
        MinWidth="1024"
        MinHeight="640"
        Title="{Binding WindowTitle}"
        Background="#000000"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        mc:Ignorable="d">
  <Grid>
    <!-- 视频画面 + HUD 叠层 -->
    <Grid>
      <video:VideoView DataContext="{Binding Video}" />
      <hud:HudOverlay DataContext="{Binding Hud}" />

      <!-- 左上角：连接状态 -->
      <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="18" Spacing="8">
        <Border Classes="status-chip warning-chip">
          <TextBlock Classes="chip-text" Text="{Binding MqttStatusLabel}" />
        </Border>
        <Border Classes="status-chip outline-chip">
          <TextBlock Classes="chip-text" Text="{Binding VideoStatusLabel}" />
        </Border>
      </StackPanel>

      <!-- 右上角：当前机器人 -->
      <Border Classes="status-chip accent-chip"
              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="18">
        <StackPanel Spacing="2">
          <TextBlock Classes="chip-text" Text="ROBOT" />
          <TextBlock Classes="chip-text" Text="{Binding CurrentRobotLabel}" />
        </StackPanel>
      </Border>

      <!-- 右下角：状态信息 -->
      <Border Classes="status-chip outline-chip"
              HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="18">
        <TextBlock Classes="chip-text" Text="{Binding StatusFootnote}" />
      </Border>
    </Grid>
  </Grid>
</Window>
