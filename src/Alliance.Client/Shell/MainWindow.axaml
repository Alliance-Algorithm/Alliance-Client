<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hud="using:Alliance.Client.Features.Hud"
        xmlns:vm="using:Alliance.Client.Shell"
        x:Class="Alliance.Client.Shell.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1360"
        Height="820"
        MinWidth="1024"
        MinHeight="640"
        Title="{Binding WindowTitle}"
        Background="#000000"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        mc:Ignorable="d">
  <Grid>
    <hud:HudOverlay DataContext="{Binding Hud}" />

    <!-- 设置按钮（视频区域左上角） -->
    <Border Classes="settings-btn"
            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30,30,0,0"
            PointerPressed="OnSettingsPressed" ZIndex="300">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center"
                   Foreground="{DynamicResource AccentBrush}" />
        <TextBlock Text="Settings" FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
